# GEMINI_API_KEY: Used for structure generation and server-side research/background fallback.
# In both local and production environments, the server consumes this key directly.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# IMAGE_API_KEY: Optional dedicated key for image generation (gemini-3.1-flash-image-preview).
# If omitted, the server falls back to GEMINI_API_KEY. API_KEY is also accepted as a legacy alias.
IMAGE_API_KEY="MY_IMAGE_API_KEY"

# PORT: Server port (default: 3000)
PORT="3000"

# APP_URL: The URL where this app is hosted.
# Used for self-referential links and OAuth callbacks.
APP_URL="http://localhost:3000"

# NOTE: Environment variables are loaded by the Express server during local development
# using dotenv (imported in server.ts). They are NOT exposed to the client bundle.
# /api/runtime-config returns only availability flags, never the key values themselves.
# UI-entered API keys are treated as an optional fallback and stored in localStorage.
