# GEMINI_API_KEY: Required for Gemini AI API calls.
# Development-only fallback. In production, users must provide their own keys via UI.
# Used for structure generation (gemini-3.1-pro-preview).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# API_KEY: Required for image generation (gemini-3.1-flash-image-preview).
# Requires a paid Google Cloud project API key.
# Development-only fallback. In production, users must provide their own keys via UI.
API_KEY="MY_PAID_API_KEY"

# PORT: Server port (default: 3000)
PORT="3000"

# APP_URL: The URL where this app is hosted.
# Used for self-referential links and OAuth callbacks.
APP_URL="http://localhost:3000"

# NOTE: Environment variables are loaded by the Express server during local development
# using dotenv (imported in server.ts). They are NOT exposed to the client bundle.
# The server exposes them through /api/runtime-config only when NODE_ENV !== 'production'.
# In production, users must input their own API keys through the UI, which are stored
# in localStorage for convenience.
